# ===========================================
# SPINE Platform - Secrets & user-provided values
#
# Copy this file to .env and fill in the values below.
# Only variables that you must change (secrets, credentials, your IDs) are here.
# All other configuration is in docker-compose.minimal.yml.
# ===========================================

# -----------------------------------------------------------------------------
# General Configuration
# -----------------------------------------------------------------------------
NODE_ENV=prod       # Available values: dev, prod
LOG_LEVEL=error     # Available levels: error, warn, info, http, verbose, debug, silly

# -----------------------------------------------------------------------------
# Empathic Building (EB Subscriber) – required for EB ingestion
# -----------------------------------------------------------------------------
# Use either (a) bearer token OR (b) username + password

# Option (a): Bearer token (if you have one)
# EB_BEARER_TOKEN=your-bearer-token

# Option (b): Username and password (required if no bearer token)
EB_USERNAME=your-email@example.com
EB_PASSWORD=your-password

# Your organization and location IDs (comma-separated)
EB_ORGANIZATION_IDS=10
EB_LOCATION_IDS=7

# Campus mapping: external EB locationId -> internal campusId (JSON)
# Example: '{"7":"campus-1","8":"campus-2"}''
EB_LOCATION_TO_CAMPUS_MAP='{"7":"MP"}'

# -----------------------------------------------------------------------------
# MQTT Broker – optional (leave empty if broker has no auth)
# -----------------------------------------------------------------------------
MQTT_USERNAME=mqtt-broker-username
MQTT_PASSWORD=mqtt-broker-password

# -----------------------------------------------------------------------------
# Storage Databases – required for storage database services
# URL format: "<username>:<password>@<host>:<port>/<database_name>"
# -----------------------------------------------------------------------------
DATABASE_URL_PLATFORM="username:password@postgres:5432/platform"
DATABASE_URL_TIMESCALE="username:password@timescaledb:5432/timescale"
DATABASE_URL_MINIO="username:password@minio:9000/minio"


# -----------------------------------------------------------------------------
# Kafka + Schema Registry Configuration
# Kafka brokers are seperated by comma (e.g. <host_1>:<port_1>,<host_2>:<port_2>,...)
# -----------------------------------------------------------------------------
KAFKA_BROKERS=kafka:9092
SCHEMA_REGISTRY_URL=http://schema-registry:8081
