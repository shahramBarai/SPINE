{
    "name": "spine",
    "version": "1.0.0",
    "private": true,
    "packageManager": "pnpm@10.33.2",
    "type": "module",
    "pnpm": {
        "overrides": {
            "@spine/shared": "workspace:*",
            "@spine/messaging": "workspace:*",
            "@spine/ingress": "workspace:*",
            "@spine/storage-platform": "workspace:*",
            "@spine/storage-minio": "workspace:*",
            "@spine/storage-timescale": "workspace:*"
        }
    },
    "scripts": {
        "pretype-check": "pnpm -r --filter ./packages run build",
        "type-check": "npm run pretype-check && pnpm -r --if-present run type-check",
        "lint": "pnpm exec eslint . --ext .ts,.js",
        "lint:app": "pnpm exec eslint modules/app --ext .ts,.js",
        "lint:egress": "pnpm exec eslint modules/egress --ext .ts,.js",
        "lint:ingress": "pnpm exec eslint modules/ingress --ext .ts,.js",
        "lint:messaging": "pnpm exec eslint modules/messaging --ext .ts,.js",
        "lint:modeling": "pnpm exec eslint modules/modeling --ext .ts,.js",
        "lint:processing": "pnpm exec eslint modules/processing --ext .ts,.js",
        "lint:storage": "pnpm exec eslint modules/storage --ext .ts,.js",
        "lint:packages": "pnpm exec eslint packages --ext .ts,.js",
        "lint:fix": "pnpm exec eslint . --ext .ts,.js --fix",
        "lint:fix:app": "pnpm exec eslint modules/app --ext .ts,.js --fix",
        "lint:fix:egress": "pnpm exec eslint modules/egress --ext .ts,.js --fix",
        "lint:fix:ingress": "pnpm exec eslint modules/ingress --ext .ts,.js --fix",
        "lint:fix:messaging": "pnpm exec eslint modules/messaging --ext .ts,.js --fix",
        "lint:fix:modeling": "pnpm exec eslint modules/modeling --ext .ts,.js --fix",
        "lint:fix:processing": "pnpm exec eslint modules/processing --ext .ts,.js --fix",
        "lint:fix:storage": "pnpm exec eslint modules/storage --ext .ts,.js --fix",
        "lint:fix:packages": "pnpm exec eslint packages --ext .ts,.js --fix",
        "format": "pnpm exec prettier --check .",
        "format:app": "pnpm exec prettier --check modules/app",
        "format:egress": "pnpm exec prettier --check modules/egress",
        "format:ingress": "pnpm exec prettier --check modules/ingress",
        "format:messaging": "pnpm exec prettier --check modules/messaging",
        "format:modeling": "pnpm exec prettier --check modules/modeling",
        "format:processing": "pnpm exec prettier --check modules/processing",
        "format:storage": "pnpm exec prettier --check modules/storage",
        "format:packages": "pnpm exec prettier --check packages",
        "format:fix": "pnpm exec prettier --write .",
        "format:fix:app": "pnpm exec prettier --write modules/app",
        "format:fix:egress": "pnpm exec prettier --write modules/egress",
        "format:fix:ingress": "pnpm exec prettier --write modules/ingress",
        "format:fix:messaging": "pnpm exec prettier --write modules/messaging",
        "format:fix:modeling": "pnpm exec prettier --write modules/modeling",
        "format:fix:processing": "pnpm exec prettier --write modules/processing",
        "format:fix:storage": "pnpm exec prettier --write modules/storage",
        "format:fix:packages": "pnpm exec prettier --write packages"
    },
    "devDependencies": {
        "@eslint/js": "catalog:",
        "@typescript-eslint/eslint-plugin": "catalog:",
        "@typescript-eslint/parser": "catalog:",
        "eslint": "catalog:",
        "globals": "catalog:",
        "prettier": "catalog:",
        "typescript": "catalog:",
        "typescript-eslint": "catalog:"
    }
}
