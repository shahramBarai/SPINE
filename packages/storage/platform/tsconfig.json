{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@spine/storage-platform": [
        "src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "prisma/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
}