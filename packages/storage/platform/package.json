{
  "name": "@spine/storage-platform",
  "version": "1.0.0",
  "description": "Platform database services for SPINE",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./prisma/types.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:init": "pnpm db:push && pnpm db:generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@spine/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "dotenv": "catalog:",
    "@types/pg": "^8.16.0",
    "prisma": "^7.4.0",
    "tsx": "^3.14.0"
  }
}