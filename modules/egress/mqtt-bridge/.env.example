# ===========================================
# MQTT Bridge Service Environment Configuration
# Local deployment: COPY it into the .env and adjust it
# Docker deployment: COPY it into the .env and adjust it
# Docker Compose deployment: -
# ===========================================

CLIENT_ID=mqtt-bridge-service
NODE_ENV=dev
HOST=0.0.0.0
PORT=3000

# Kafka Settings (Consumer)
KAFKA_BROKERS=kafka:29092
KAFKA_TOPIC_SENSOR_DATA=sensor-data

# Kafka connection settings (optional, with defaults)
# KAFKA_CONNECTION_TIMEOUT=10000
# KAFKA_REQUEST_TIMEOUT=30000
# KAFKA_RETRY_RETRIES=5

# MQTT Settings (Publisher)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_QOS=0
MQTT_RETAIN=false
MQTT_KEEPALIVE=60
MQTT_RECONNECT_PERIOD=1000
MQTT_CONNECT_TIMEOUT=30000
MQTT_USERNAME=mqtt-broker-username
MQTT_PASSWORD=mqtt-broker-password